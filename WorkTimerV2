function buildDayView(){
  var i=activeDay;var day=D.days[i];var d=WD[i];
  var sl=document.getElementById('secLbl');
  var sd=document.getElementById('secDate');
  if(sl)sl.textContent='Tâches · '+DAYS[i];
  if(sd)sd.textContent=d.getDate().toString().padStart(2,'0')+'.'+(d.getMonth()+1).toString().padStart(2,'0')+'.'+d.getFullYear();

  var wrap=document.getElementById('tasksWrap');
  if(wrap){
    wrap.innerHTML=day.tasks.map(function(t){return taskCardHTML(t,i);}).join('')
      +'<button class="add-task" id="addTaskBtn"><svg viewBox="0 0 24 24" stroke-linecap="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>Nouvelle tâche</button>';
    attachTaskEvents(i);
  }
  buildHoraires(i);
  var na=document.getElementById('notesArea');
  if(na){na.value=day.notes||'';na.oninput=function(){D.days[i].notes=na.value;save();};}
  repaintRing(i);
}

function attachTaskEvents(i){
  var wrap=document.getElementById('tasksWrap');if(!wrap)return;
  // Add task
  var ab=document.getElementById('addTaskBtn');
  if(ab)ab.onclick=function(){
    D.days[i].tasks.push({id:Date.now(),client:'',object:'',elapsed:0,manual:'',recurring:false,locked:false});
    save();buildDayView();
  };
  // Play/pause
  wrap.querySelectorAll('[data-tid]').forEach(function(btn){
    btn.onclick=function(){
      var tid=parseInt(btn.dataset.tid),di=parseInt(btn.dataset.di);
      var isR=runningTimer&&runningTimer.taskId===tid&&runningTimer.dayIdx===di&&runningTimer.wk===weekOffset;
      if(isR)pauseTimer(tid,di);else startTimer(tid,di);
      buildDayView();repaintRing(i);
    };
  });
  // Reset
  wrap.querySelectorAll('[data-rid]').forEach(function(btn){
    btn.onclick=function(){
      if(!confirm('Remettre à zéro ?'))return;
      var tid=parseInt(btn.dataset.rid),di=parseInt(btn.dataset.di);
      if(runningTimer&&runningTimer.taskId===tid&&runningTimer.dayIdx===di){runningTimer=null;clearInterval(tickInterval);tickInterval=null;persistTimer();}
      var t=D.days[di].tasks.find(function(t){return t.id===tid;});
      if(t)t.elapsed=0;
      save();buildDayView();repaintRing(i);updateBanner();
    };
  });
  // Delete
  wrap.querySelectorAll('[data-del]').forEach(function(btn){
    btn.onclick=function(){
      if(!confirm('Supprimer ?'))return;
      var tid=parseInt(btn.dataset.del);
      if(runningTimer&&runningTimer.taskId===tid){runningTimer=null;clearInterval(tickInterval);tickInterval=null;persistTimer();}
      D.days[i].tasks=D.days[i].tasks.filter(function(t){return t.id!==tid;});
      save();buildDayView();repaintRing(i);
    };
  });
  // Lock
  wrap.querySelectorAll('[data-lock]').forEach(function(btn){
    btn.onclick=function(){
      var tid=parseInt(btn.dataset.lock),di=parseInt(btn.dataset.di);
      var t=D.days[di].tasks.find(function(t){return t.id===tid;});
      if(!t)return;
      if(t.locked){t.locked=false;}
      else{
        if(runningTimer&&runningTimer.taskId===tid)pauseTimer(tid,di);
        t.locked=true;
        if(!t.manual&&t.elapsed>0)t.manual=s2hm_rnd(t.elapsed);
        else if(t.manual)t.manual=roundManual(t.manual);
      }
      save();buildDayView();buildWeekView();buildCopyView();
    };
  });
  // Carry
  wrap.querySelectorAll('[data-carry]').forEach(function(btn){
    btn.onclick=function(){
      var tid=parseInt(btn.dataset.carry),di=parseInt(btn.dataset.di);
      var t=D.days[di].tasks.find(function(t){return t.id===tid;});
      if(!t||t.carriedTo)return;
      var ni=di===4?0:di+1;
      var copy=JSON.parse(JSON.stringify(t));
      copy.id=Date.now();copy.elapsed=0;copy.manual='';copy.carriedFrom=tid;copy.locked=false;copy.carriedTo=null;
      t.carriedTo=copy.id;
      if(di<4)D.days[ni].tasks.push(copy);
      save();buildDayView();showToast('↷ Reporté à '+DAYS[ni==='0'?0:ni]);
    };
  });
  // Inputs
  wrap.querySelectorAll('[data-f]').forEach(function(el){
    el.oninput=function(){
      var id=parseInt(el.dataset.id),f=el.dataset.f;
      var t=D.days[i].tasks.find(function(t){return t.id===id;});
      if(t){t[f]=el.value;if(f!=='manual'){save();buildWeekView();buildCopyView();}}
    };
    if(el.dataset.f==='manual'){
      el.onblur=function(){
        var id=parseInt(el.dataset.id);
        var t=D.days[i].tasks.find(function(t){return t.id===id;});
        if(t&&el.value){el.value=roundManual(el.value);t.manual=el.value;save();buildWeekView();buildCopyView();}
      };
    }
  });
}

function refreshTask(tid,di){
  var card=document.getElementById('ti_'+tid);if(!card)return;
  var t=D.days[di].tasks.find(function(t){return t.id===tid;});if(!t)return;
  var tmp=document.createElement('div');tmp.innerHTML=taskCardHTML(t,di);
  card.replaceWith(tmp.firstElementChild);
  attachTaskEvents(di);
}

