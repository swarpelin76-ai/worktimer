function buildDayStrip(){
  var wrap=document.getElementById('dayStrip');if(!wrap)return;
  wrap.innerHTML='';
  DAYS.forEach(function(_,i){
    var d=WD[i];
    var day=D.days[i];
    var filled=day.tasks.some(function(t){return t.elapsed>0||t.manual;});
    var btn=document.createElement('button');
    btn.className='day-pill'+(i===activeDay?' active':'');
    btn.innerHTML='<span class="dp-name">'+DS[i]+'</span>'
      +'<span class="dp-date">'+d.getDate().toString().padStart(2,'0')+'.'+(d.getMonth()+1).toString().padStart(2,'0')+'</span>'
      +(filled?'<div class="dp-dot"></div>':'');
    btn.onclick=(function(idx){return function(){activeDay=idx;buildDayStrip();buildDayView();};})(i);
    wrap.appendChild(btn);
  });
}

