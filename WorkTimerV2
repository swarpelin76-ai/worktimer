<script>
// ═══════════════════════════════════════════
//  CONSTANTS & STATE
// ═══════════════════════════════════════════
var DAYS=['Lundi','Mardi','Mercredi','Jeudi','Vendredi'];
var DS=['Lun','Mar','Mer','Jeu','Ven'];
var TARGET=525; // 8h45
var PAUSES=[0,15,30,45,60,75,90];
var RKEY='pmAlpes_rappels';
var TKEY='pmAlpes_timer';

var activeDay=0, activeTab=0, weekOffset=0;
var runningTimer=null, tickInterval=null;
var rapportWeeks=4, rapportData={};
var D=null, WD=[];

// ═══════════════════════════════════════════
//  WEEK UTILS
// ═══════════════════════════════════════════
function getMon(offset){
  var t=new Date(),dow=t.getDay();
  var mon=new Date(t);
  mon.setDate(t.getDate()-(dow===0?6:dow-1)+(offset||0)*7);
  mon.setHours(0,0,0,0);
  return mon;
}
function getWD(offset){
  var mon=getMon(offset);
  return Array.from({length:5},function(_,i){var d=new Date(mon);d.setDate(mon.getDate()+i);return d;});
}
function weekKey(offset){
  return 'pmAlpes_'+getMon(offset).toISOString().slice(0,10);
}

// ═══════════════════════════════════════════
//  DATA
// ═══════════════════════════════════════════
function defTask(seed,cl,obj){return{id:Date.now()+seed,client:cl,object:obj,elapsed:0,manual:'',recurring:true,locked:false};}
function defDay(i){return{start:'07:00',end:'17:00',pause:90,notes:'',tasks:[defTask(i*300+1,'Débitage standard',''),defTask(i*300+2,'Atelier bureau','Rangement / organisation')]};}
function defWeek(){return{days:DAYS.map(function(_,i){return defDay(i);})};}

function loadWeek(offset){
  weekOffset=offset;
  WD=getWD(offset);
  var key=weekKey(offset);
  var raw=null;
  try{raw=JSON.parse(localStorage.getItem(key)||'null');}catch(e){}
  D=raw||defWeek();
  // Migrate
  D.days.forEach(function(day,i){
    if(!day.tasks)day.tasks=[];
    day.tasks.forEach(function(t){
      if(!t.id)t.id=Date.now()+Math.random()*1000|0;
      if(t.elapsed==null)t.elapsed=0;
      if(t.manual==null)t.manual='';
      if(t.client==null){t.client=t.name||'';delete t.name;}
      if(t.object==null)t.object='';
      if(t.recurring)t.locked=false;
    });
    if(!day.tasks.length){
      day.tasks.push(defTask(i*300+1,'Débitage standard',''));
      day.tasks.push(defTask(i*300+2,'Atelier bureau','Rangement / organisation'));
    }
  });
  updateWkLabel();
  updateNavBtns();
}

function save(){
  var key=weekKey(weekOffset);
  try{localStorage.setItem(key,JSON.stringify(D));}catch(e){}
}

function updateWkLabel(){
  var el=document.getElementById('wkLabel');
  if(!el)return;
  var mon=getMon(weekOffset);
  var dd=mon.getDate().toString().padStart(2,'0');
  var mm=(mon.getMonth()+1).toString().padStart(2,'0');
  if(weekOffset===0){el.textContent='Sem. '+dd+'.'+mm;el.className='wk-badge now';}
  else if(weekOffset<0){el.textContent='◀ S'+Math.abs(weekOffset)+' '+dd+'.'+mm;el.className='wk-badge';}
  else{el.textContent='S'+weekOffset+' ▶ '+dd+'.'+mm;el.className='wk-badge';}
}

function updateNavBtns(){
  var p=document.getElementById('wkPrev');
  var n=document.getElementById('wkNext');
  if(p)p.disabled=(weekOffset<=-1);
  if(n)n.disabled=(weekOffset>=2);
}

function changeWeek(dir){
  var no=weekOffset+dir;
  if(no<-1||no>2)return;
  // Pause timer avant de changer
  if(runningTimer)commitTimer();
  save();
  loadWeek(no);
  buildDayStrip();
  buildDayView();
  if(activeTab===1)buildWeekView();
  if(activeTab===2)buildCopyView();
  showToast(weekOffset===0?'Semaine courante':(weekOffset<0?'Semaine précédente':'Semaine +'+weekOffset));
}

// ═══════════════════════════════════════════
//  HELPERS
// ═══════════════════════════════════════════
function t2m(t){if(!t)return null;var p=t.split(':').map(Number);return p[0]*60+(p[1]||0);}
function m2hm(m){if(m==null||isNaN(m)||m<0)return '--h--';return Math.floor(m/60)+'h'+String(m%60).padStart(2,'0');}
function rQ(m){return Math.round(m/15)*15;}
function s2hms(s){var h=Math.floor(s/3600),m=Math.floor((s%3600)/60),ss=s%60;return String(h).padStart(2,'0')+':'+String(m).padStart(2,'0')+':'+String(ss).padStart(2,'0');}
function s2hm_rnd(s){var r=Math.round(s/60/15)*15;return Math.floor(r/60)+'h'+String(r%60).padStart(2,'0');}
function netMin(day){var s=t2m(day.start),e=t2m(day.end);if(!s||!e)return null;var r=e-s-(day.pause||0);return r>0?r:0;}
function rndMin(day){var n=netMin(day);return n==null?null:rQ(n);}
function taskLabel(t){var c=(t.client||'').trim(),o=(t.object||'').trim();if(c&&o)return c+' — '+o;return c||o||'Sans nom';}
function esc(s){return String(s||'').replace(/[&<"]/g,function(c){var m={'&':'&amp;','<':'&lt;','"':'&quot;'};return m[c]||c;});}

function roundManual(v){
  if(!v)return v;
  var s=v.trim();
  var mH=s.match(/^(\d+)h(\d*)$/);
  var mC=s.match(/^(\d+):(\d{2})$/);
  var mM=s.match(/^(\d+)$/);
  var tot=0;
  if(mH)tot=parseInt(mH[1])*60+(parseInt(mH[2]||'0')||0);
  else if(mC)tot=parseInt(mC[1])*60+parseInt(mC[2]);
  else if(mM)tot=parseInt(mM[1]);
  else return v;
  var r=Math.round(tot/15)*15;
  return Math.floor(r/60)+'h'+String(r%60).padStart(2,'0');
}

function showToast(msg,dur){
  if(!dur)dur=1800;
  var t=document.getElementById('toast');
  if(!t)return;
  t.textContent=msg;t.classList.add('show');
  clearTimeout(t._t);t._t=setTimeout(function(){t.classList.remove('show');},dur);
}

// ═══════════════════════════════════════════
//  TIMER — persistant via localStorage
// ═══════════════════════════════════════════
function getLive(tid,di){
  var day=D.days[di];
  var t=day?day.tasks.find(function(t){return t.id===tid;}):null;
  if(!t)return 0;
  var e=t.elapsed||0;
  if(runningTimer&&runningTimer.taskId===tid&&runningTimer.dayIdx===di&&runningTimer.wk===weekOffset)
    e+=Math.floor((Date.now()-runningTimer.startedAt)/1000);
  return e;
}

function persistTimer(){
  if(runningTimer){
    try{localStorage.setItem(TKEY,JSON.stringify({taskId:runningTimer.taskId,dayIdx:runningTimer.dayIdx,startedAt:runningTimer.startedAt,wk:runningTimer.wk,weekKey:weekKey(runningTimer.wk)}));}catch(e){}
  }else{
    try{localStorage.removeItem(TKEY);}catch(e){}
  }
}

function restoreTimer(){
  try{
    var s=JSON.parse(localStorage.getItem(TKEY)||'null');
    if(!s||!s.startedAt)return;
    // Vérifier que la clé de semaine correspond à la semaine offset courante
    if(s.weekKey===weekKey(s.wk||0)){
      runningTimer={taskId:s.taskId,dayIdx:s.dayIdx,startedAt:s.startedAt,wk:s.wk||0};
    }
  }catch(e){}
}

function commitTimer(){
  if(!runningTimer)return;
  var tid=runningTimer.taskId,di=runningTimer.dayIdx,wk=runningTimer.wk||0;
  if(wk===weekOffset){
    var day=D.days[di];
    var t=day?day.tasks.find(function(t){return t.id===tid;}):null;
    if(t)t.elapsed=(t.elapsed||0)+Math.floor((Date.now()-runningTimer.startedAt)/1000);
  }
  clearInterval(tickInterval);tickInterval=null;runningTimer=null;
  persistTimer();
  save();
}

function startTimer(tid,di){
  if(runningTimer)commitTimer();
  runningTimer={taskId:tid,dayIdx:di,startedAt:Date.now(),wk:weekOffset};
  persistTimer();
  if(!tickInterval)tickInterval=setInterval(tick,1000);
  updateBanner();
  refreshTask(tid,di);
}

function pauseTimer(tid,di){
  if(!runningTimer||runningTimer.taskId!==tid||runningTimer.dayIdx!==di)return;
  commitTimer();
  updateBanner();
  refreshTask(tid,di);
}

function tick(){
  if(!runningTimer){clearInterval(tickInterval);tickInterval=null;return;}
  var tid=runningTimer.taskId,di=runningTimer.dayIdx;
  var disp=document.getElementById('td_'+tid);
  if(disp)disp.textContent=s2hms(getLive(tid,di));
  var lt=document.getElementById('liveTime');if(lt)lt.textContent=s2hms(getLive(tid,di));
  repaintRing(di);
  if(activeTab===2)buildCopyView();
}

function updateBanner(){
  var b=document.getElementById('liveBanner');if(!b)return;
  if(!runningTimer){b.classList.remove('on');return;}
  var day=D.days[runningTimer.dayIdx];
  var t=day?day.tasks.find(function(x){return x.id===runningTimer.taskId;}):null;
  var lt=document.getElementById('liveTask');if(lt)lt.textContent=(t?(t.client||t.object||'Tâche'):'Tâche').slice(0,22);
  var ltime=document.getElementById('liveTime');if(ltime)ltime.textContent=s2hms(getLive(runningTimer.taskId,runningTimer.dayIdx));
  b.classList.add('on');
}

// ═══════════════════════════════════════════
//  RING
// ═══════════════════════════════════════════
var CIRC=238.8;
function repaintRing(di){
  var day=D.days[di];
  // Ring = total des tâches avec temps réel (timer ou manuel non vide)
  var taskMin=0;
  day.tasks.forEach(function(t){
    var el=getLive(t.id,di);
    // Ignorer les tâches récurrentes sans temps saisi
    if(t.recurring && !t.manual && el===0) return;
    var dur=t.manual||(el>0?s2hm_rnd(el):null);
    if(!dur)return;
    var mH=dur.match(/^(\d+)h(\d*)$/);
    if(mH)taskMin+=parseInt(mH[1])*60+(parseInt(mH[2]||'0')||0);
  });
  var r=Math.round(taskMin/15)*15;
  var pct=Math.min(1,r/TARGET);
  var prog=document.getElementById('ringProg');
  if(prog){
    prog.style.strokeDashoffset=CIRC*(1-pct);
    prog.classList.toggle('over',r>TARGET);
    prog.style.opacity=r>0?'1':'0';
  }
  var rv=document.getElementById('ringVal');if(rv)rv.textContent=r?m2hm(r):'—';
  var diff=r-TARGET;
  var rd=document.getElementById('rsDiff');var rdet=document.getElementById('rsDetail');
  if(rd){
    if(!r){rd.textContent='Pas encore saisi';rd.className='rs-diff';rd.style.fontSize='.85rem';rd.style.color='var(--lbl3)';rd.style.fontStyle='italic';rd.style.fontWeight='400';}
    else if(diff>=0){rd.textContent='+'+m2hm(diff);rd.className='rs-diff';rd.style.fontSize='';rd.style.color='';rd.style.fontStyle='';rd.style.fontWeight='';}
    else{rd.textContent='−'+m2hm(Math.abs(diff));rd.className='rs-diff over';rd.style.fontSize='';rd.style.color='';rd.style.fontStyle='';rd.style.fontWeight='';}
  }
  if(rdet)rdet.textContent=r?(m2hm(r)+' · arrondi ¼h'):'8h45 · arrondi ¼h';
}

