function buildHoraires(i){
  var hc=document.getElementById('horCard');if(!hc)return;
  var day=D.days[i];
  var n=netMin(day),r=rndMin(day);
  var pb=PAUSES.map(function(p){return '<button class="pbtn'+(day.pause===p?' on':'')+'" data-p="'+p+'">'+p+'m</button>';}).join('');
  pb+='<input class="pbtn-c" type="number" min="0" max="360" value="'+(PAUSES.includes(day.pause)?'':day.pause)+'" placeholder="…">';
  hc.innerHTML='<div class="hor-fields">'
    +'<div class="hor-f"><div class="hor-lbl">Début</div><input class="hor-inp" type="time" value="'+(day.start||'')+'" data-f="start"></div>'
    +'<div class="hor-f"><div class="hor-lbl">Fin</div><input class="hor-inp" type="time" value="'+(day.end||'')+'" data-f="end"></div>'
    +'</div>'
    +'<div class="hor-pause"><div class="hor-pause-lbl">Pause</div><div class="pause-btns" id="pauseBtns">'+pb+'</div></div>'
    +'<div class="hor-dur" id="horDur">'
    +'<div class="hor-dur-info"><div class="hd-lbl">Durée nette</div><div class="hd-rnd">Arrondie ¼h → <strong>'+(r!=null?m2hm(r):'—')+'</strong></div></div>'
    +'<div class="hor-dur-val">'+(n!=null?m2hm(n):'—')+'</div>'
    +'</div>';

  function updateDur(){
    var dur=document.getElementById('horDur');if(!dur)return;
    var n2=netMin(day),r2=rndMin(day);
    dur.innerHTML='<div class="hor-dur-info"><div class="hd-lbl">Durée nette</div><div class="hd-rnd">Arrondie ¼h → <strong>'+(r2!=null?m2hm(r2):'—')+'</strong></div></div><div class="hor-dur-val">'+(n2!=null?m2hm(n2):'—')+'</div>';
    repaintRing(i);buildWeekView();buildCopyView();
  }

  hc.querySelectorAll('.hor-inp').forEach(function(inp){
    inp.onchange=function(){D.days[i][inp.dataset.f]=inp.value;save();updateDur();};
  });
  var pb_wrap=document.getElementById('pauseBtns');
  if(pb_wrap){
    pb_wrap.querySelectorAll('.pbtn').forEach(function(btn){
      btn.onclick=function(){
        D.days[i].pause=parseInt(btn.dataset.p);save();
        pb_wrap.querySelectorAll('.pbtn').forEach(function(b){b.classList.toggle('on',parseInt(b.dataset.p)===D.days[i].pause);});
        updateDur();
      };
    });
    var pc=pb_wrap.querySelector('.pbtn-c');
    if(pc)pc.onchange=function(){
      var v=parseInt(pc.value);if(!isNaN(v)){D.days[i].pause=v;save();}
      pb_wrap.querySelectorAll('.pbtn').forEach(function(b){b.classList.remove('on');});
      updateDur();
    };
  }
}

