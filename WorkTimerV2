// ═══════════════════════════════════════════
function selPer(btn){
  document.querySelectorAll('.per-btn').forEach(function(b){b.classList.remove('on');});
  btn.classList.add('on');rapportWeeks=parseInt(btn.dataset.w);
  setPeriodDates();buildRapport();
}
function setPeriodDates(){
  var to=new Date();var from=new Date();
  if(rapportWeeks>0)from.setDate(from.getDate()-rapportWeeks*7);
  else from.setFullYear(2020);
  var rf=document.getElementById('rFrom');var rt=document.getElementById('rTo');
  if(rf)rf.value=from.toISOString().slice(0,10);
  if(rt)rt.value=to.toISOString().slice(0,10);
}
function getAllKeys(fd,td){
  var keys=[];
  for(var i=0;i<localStorage.length;i++){
    var k=localStorage.key(i);
    if(!k||!k.startsWith('pmAlpes_'))continue;
    if(k===RKEY||k===TKEY)continue;
    var d=new Date(k.replace('pmAlpes_',''));
    if(d>=fd&&d<=td)keys.push(k);
  }
  return keys.sort();
}
function tsm(s){if(!s)return 0;var mH=s.match(/^(\d+)h(\d*)$/);var mC=s.match(/^(\d+):(\d{2})$/);if(mH)return parseInt(mH[1])*60+(parseInt(mH[2]||'0')||0);if(mC)return parseInt(mC[1])*60+parseInt(mC[2]);return 0;}
function buildRapport(){
  try{
    var rf=document.getElementById('rFrom');var rt=document.getElementById('rTo');
    if(!rf||!rt)return;
    var fv=rf.value,tv=rt.value;if(!fv||!tv)return;
    var fd=new Date(fv);var td=new Date(tv);td.setHours(23,59,59);
    var filter=(document.getElementById('rFilter')||{}).value||'';filter=filter.toLowerCase().trim();
    var keys=getAllKeys(fd,td);
    var cm={};
    keys.forEach(function(key){
      var wd=null;try{wd=JSON.parse(localStorage.getItem(key)||'null');}catch(e){}
      if(!wd)return;
      var mon=new Date(key.replace('pmAlpes_',''));
      wd.days.forEach(function(day,di){
        var dd=new Date(mon);dd.setDate(mon.getDate()+di);
        if(dd<fd||dd>td)return;
        var ds=dd.toLocaleDateString('fr-CH',{day:'2-digit',month:'2-digit',year:'numeric'});
        day.tasks.forEach(function(t){
          var cl=(t.client||'').trim();
          if(!cl||cl==='Débitage standard'||cl==='Atelier bureau')return;
          var ts=t.manual||(t.elapsed>0?s2hm_rnd(t.elapsed):null);if(!ts)return;
          if(filter&&cl.toLowerCase().indexOf(filter)===-1)return;
          if(!cm[cl])cm[cl]=[];
          cm[cl].push({date:ds,objet:(t.object||'').trim(),ts:ts,locked:t.locked||false});
        });
      });
    });
    rapportData=cm;
    var wrap=document.getElementById('rapportWrap');
    var exp=document.getElementById('rapportExport');
    if(!wrap)return;
    var clients=Object.keys(cm).sort();
    if(!clients.length){
      wrap.innerHTML='<div class="empty-st"><div class="ei">🔍</div><div class="et">Aucun client trouvé</div><div class="es">Ajoutez des noms de clients à vos tâches</div></div>';
      if(exp)exp.style.display='none';return;
    }
    var gt=0;clients.forEach(function(cl){cm[cl].forEach(function(r){gt+=tsm(r.ts);});});
    var fd2=new Date(fv).toLocaleDateString('fr-CH',{day:'2-digit',month:'2-digit',year:'numeric'});
    var td2=new Date(tv).toLocaleDateString('fr-CH',{day:'2-digit',month:'2-digit',year:'numeric'});
    var html='<div class="cl-total-card"><div><div class="ctc-l">Total période</div><div class="ctc-p">'+fd2+' → '+td2+'</div></div><div class="ctc-v">'+m2hm(gt)+'</div></div>';
    clients.forEach(function(cl){
      var rows=cm[cl];var tot=rows.reduce(function(s,r){return s+tsm(r.ts);},0);
      var rh=rows.map(function(r){return '<div class="cl-row"><div class="cl-dt">'+r.date+'</div><div class="cl-ob">'+(r.objet||'—')+'</div><div class="cl-tm">'+r.ts+'</div>'+(r.locked?'<span class="cl-ck">✓</span>':'')+'</div>';}).join('');
      html+='<div class="cl-block"><div class="cl-block-head"><div class="cl-name">'+esc(cl)+'</div><div class="cl-tot">'+m2hm(tot)+'</div></div>'+rh+'</div>';
    });
    wrap.innerHTML=html;
    if(exp)exp.style.display='flex';
  }catch(e){var w=document.getElementById('rapportWrap');if(w)w.innerHTML='<div style="padding:20px;color:var(--red);font-size:.85rem;">'+e.message+'</div>';}
}
function rapportText(){
  var rf=document.getElementById('rFrom'),rt=document.getElementById('rTo');
  var fd=rf?new Date(rf.value).toLocaleDateString('fr-CH',{day:'2-digit',month:'2-digit',year:'numeric'}):'';
  var td=rt?new Date(rt.value).toLocaleDateString('fr-CH',{day:'2-digit',month:'2-digit',year:'numeric'}):'';
  var txt='RAPPORT PM ALPES SA\nPériode: '+fd+' → '+td+'\n'+'═'.repeat(36)+'\n\n';
  var gt=0;
  Object.keys(rapportData).sort().forEach(function(cl){
    var rows=rapportData[cl];var tot=rows.reduce(function(s,r){return s+tsm(r.ts);},0);gt+=tot;
    txt+='▸ '+cl+' — '+m2hm(tot)+'\n';
    rows.forEach(function(r){txt+='  '+r.date+'  '+(r.objet?r.objet+' ':'')+': '+r.ts+(r.locked?' ✓':'')+'\n';});
    txt+='\n';
  });
  txt+='═'.repeat(36)+'\nTOTAL: '+m2hm(gt)+'\n';
  return txt;
}
function copyRapport(){navigator.clipboard.writeText(rapportText()).then(function(){showToast('✓ Rapport copié');});}
function exportRapport(){
  var b=new Blob([rapportText()],{type:'text/plain'});var a=document.createElement('a');a.href=URL.createObjectURL(b);
  var rf=document.getElementById('rFrom'),rt=document.getElementById('rTo');
  a.download='Rapport_PMAlpes_'+(rf?rf.value:'')+'-'+(rt?rt.value:'')+'.txt';a.click();showToast('✓ Exporté');
}

// ═══════════════════════════════════════════
//  RAPPELS
// ═══════════════════════════════════════════
function getRappels(){try{return JSON.parse(localStorage.getItem(RKEY)||'[]');}catch(e){return [];}}
function setRappels(r){try{localStorage.setItem(RKEY,JSON.stringify(r));}catch(e){}}
function addRappel(){
  var d=document.getElementById('rpDate'),m=document.getElementById('rpMsg');
  if(!d||!m)return;
  if(!d.value){showToast('Choisissez une date');return;}
  if(!m.value.trim()){showToast('Entrez un message');return;}
  var r=getRappels();r.push({id:Date.now(),date:d.value,msg:m.value.trim()});
  r.sort(function(a,b){return a.date.localeCompare(b.date);});
  setRappels(r);d.value='';m.value='';
  buildRappels();showToast('✓ Rappel ajouté');checkAlerts();
}
function delRappel(id){setRappels(getRappels().filter(function(r){return r.id!==id;}));buildRappels();checkAlerts();}
function buildRappels(){
  var wrap=document.getElementById('rpList');if(!wrap)return;
  var r=getRappels();var today=new Date().toISOString().slice(0,10);
  if(!r.length){wrap.innerHTML='<div class="rp-empty">Aucun rappel</div>';return;}
  wrap.innerHTML=r.map(function(item){
    var isT=item.date===today;var isP=item.date<today;
    var d=new Date(item.date+'T00:00:00');
    var ds=isT?'⚡ AUJOURD\'HUI':d.toLocaleDateString('fr-CH',{weekday:'short',day:'2-digit',month:'long',year:'numeric'});
    var icon=isT?'⚠️':(isP?'✓':'🔔');
    return '<div class="rp-item'+(isT?' today':isP?' past':'')+'">'
      +'<div class="rp-icon">'+icon+'</div>'
      +'<div class="rp-info"><div class="rp-date'+(isT?' today':'')+'">'+ds+'</div><div class="rp-msg">'+esc(item.msg)+'</div></div>'
      +'<button class="rp-del" onclick="try{delRappel('+item.id+')}catch(e){}">✕</button>'
      +'</div>';
  }).join('');
}
function checkAlerts(){
  var today=new Date().toISOString().slice(0,10);
  var has=getRappels().some(function(r){return r.date===today;});
  var t=document.getElementById('tab4');
  if(t)t.classList.toggle('alert',has);
}

// ═══════════════════════════════════════════
//  NAVIGATION
// ═══════════════════════════════════════════
function goTab(idx,btn){
  document.querySelectorAll('.tab').forEach(function(b){b.classList.remove('active');});
  btn.classList.add('active');
  document.querySelectorAll('.page').forEach(function(p,i){p.classList.toggle('active',i===idx);});
  activeTab=idx;
  if(idx===1)buildWeekView();
  if(idx===2)buildCopyView();
  if(idx===3){try{setPeriodDates();buildRapport();}catch(e){}}
  if(idx===4){buildRappels();}
}

// ═══════════════════════════════════════════
//  INIT
// ═══════════════════════════════════════════
try{
  // Charger la semaine courante
  loadWeek(0);
  var dow=new Date().getDay();if(dow>=1&&dow<=5)activeDay=dow-1;

  // Restaurer le timer depuis localStorage
  restoreTimer();

  // Construire l'UI
  buildDayStrip();
  buildDayView();
  buildWeekView();
  buildCopyView();
  setPeriodDates();
  buildRappels();
  checkAlerts();
  updateBanner();

  // Démarrer l'intervalle si timer en cours
  if(runningTimer&&!tickInterval)tickInterval=setInterval(tick,1000);

  // Visibilité — quand on revient sur l'app
  document.addEventListener('visibilitychange',function(){
    try{
      if(document.visibilityState==='visible'){
        if(runningTimer){
          if(tickInterval){clearInterval(tickInterval);tickInterval=null;}
          tickInterval=setInterval(tick,1000);
          tick();updateBanner();
          buildDayStrip();buildDayView();
        }
      } else {
        if(runningTimer)save();
      }
    }catch(e){}
  });

  window.addEventListener('focus',function(){
    try{if(runningTimer){
      if(tickInterval){clearInterval(tickInterval);tickInterval=null;}
      tickInterval=setInterval(tick,1000);
      tick();
    }}catch(e){}
  });

  // Clique sur la semaine courante pour revenir
  document.getElementById('wkLabel').onclick=function(){if(weekOffset!==0)changeWeek(-weekOffset);};

  // Install banner
  try{
    var _ios=/iphone|ipad|ipod/i.test(navigator.userAgent);
    var _safari=/safari/i.test(navigator.userAgent);
    var _notchrome=!/chrome|crios|fxios/i.test(navigator.userAgent);
    var _standalone=window.navigator.standalone===true;
    var _dismissed=localStorage.getItem('installDismissed');
    if(_ios&&_safari&&_notchrome&&!_standalone&&!_dismissed){
      setTimeout(function(){var b=document.getElementById('installBanner');if(b)b.classList.add('show');},2500);
    }
    var _ib=document.getElementById('ibClose');
    if(_ib)_ib.onclick=function(){
      var b=document.getElementById('installBanner');if(b)b.classList.remove('show');
      localStorage.setItem('installDismissed','1');
    };
  }catch(e){}

}catch(e){console.error('Init error:',e.message,e.stack);}
</script>
