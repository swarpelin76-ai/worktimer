function buildWeekView(){
  var wrap=document.getElementById('wkWrap');if(!wrap)return;
  var total=0;var html='';
  DAYS.forEach(function(_,i){
    var day=D.days[i];var d=WD[i];
    var r=rndMin(day);if(r)total+=r;
    var dn=DAYS[i]+' '+d.getDate().toString().padStart(2,'0')+'.'+(d.getMonth()+1).toString().padStart(2,'0')+'.'+d.getFullYear();
    var dh=day.start&&day.end?(day.start+' → '+day.end+(r?' · '+m2hm(r):'')):'—';
    var rows='';var hasT=false;
    day.tasks.forEach(function(t){
      var el=getLive(t.id,i);var dur=t.manual||(el>0?s2hm_rnd(el):null);if(!dur)return;
      var lbl=taskLabel(t);if(lbl==='Sans nom')return;
      rows+='<div class="wk-tr"><span class="wk-tn">'+esc(lbl)+'</span><span class="wk-tt">'+dur+'</span></div>';
      hasT=true;
    });
    html+='<div class="wk-card"><div class="wk-head"><div><div class="wk-dn">'+dn+'</div><div class="wk-dh">'+dh+'</div></div>'
      +'<button class="wk-cp" data-wi="'+i+'"><svg viewBox="0 0 24 24"><rect x="9" y="2" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>Copier</button>'
      +'</div>'+(hasT?'<div class="wk-tasks-list">'+rows+'</div>':'<div class="wk-empty-t">Aucune tâche saisie</div>')
      +'</div>';
  });
  html+='<div class="wk-total-card"><div class="wtc-l">Total semaine</div><div class="wtc-v">'+m2hm(total)+'</div></div>';
  wrap.innerHTML=html;
  wrap.querySelectorAll('[data-wi]').forEach(function(btn){
    btn.onclick=function(){copyDay(parseInt(btn.dataset.wi));};
  });
}

// ═══════════════════════════════════════════
//  COPY VIEW
// ═══════════════════════════════════════════
function dayLines(i){
  var day=D.days[i];var d=WD[i];
  var lines=[];
  var dn=DAYS[i]+' '+d.getDate().toString().padStart(2,'0')+'.'+(d.getMonth()+1).toString().padStart(2,'0');
  lines.push(dn);
  var r=rndMin(day);
  if(day.start&&day.end)lines.push(day.start+' → '+day.end+(r?' ('+m2hm(r)+')':''));
  day.tasks.forEach(function(t){
    var el=getLive(t.id,i);var dur=t.manual||(el>0?s2hm_rnd(el):null);if(!dur)return;
    var lbl=taskLabel(t);if(lbl==='Sans nom')return;
    if(t.recurring&&!dur)return;
    lines.push(lbl+' : '+dur);
  });
  if(day.notes)lines.push('Notes: '+day.notes);
  return lines;
}

function copyDay(i){
  var text=dayLines(i).join('\n');
  navigator.clipboard.writeText(text).then(function(){showToast('✓ Copié');}).catch(function(){showToast(text,3000);});
}

function buildCopyView(){
  var wrap=document.getElementById('cpWrap');if(!wrap)return;
  var html='';
  DAYS.forEach(function(_,i){
    var day=D.days[i];var d=WD[i];var r=rndMin(day);
    var dn=DAYS[i]+' '+d.getDate().toString().padStart(2,'0')+'.'+(d.getMonth()+1).toString().padStart(2,'0');
    var dh=day.start&&day.end?(day.start+' → '+day.end+(r?' · '+m2hm(r):'')):'Horaires non renseignés';
    var lines=[];
    day.tasks.forEach(function(t){
      var el=getLive(t.id,i);var dur=t.manual||(el>0?s2hm_rnd(el):null);if(!dur)return;
      var lbl=taskLabel(t);if(lbl==='Sans nom')return;
      if(t.recurring&&!dur)return;
      lines.push(lbl+' : '+dur);
    });
    html+='<div class="cp-card"><div class="cp-head"><div><div class="cp-dn">'+dn+'</div><div class="cp-dh">'+dh+'</div></div>'
      +'<button class="cp-btn" data-ci="'+i+'"><svg viewBox="0 0 24 24"><rect x="9" y="2" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>Copier</button>'
      +'</div><div class="cp-lines">'+(lines.length?lines.join('\n'):'Aucune tâche')+'</div></div>';
  });
  html+='<button class="cp-all" id="cpAll"><svg viewBox="0 0 24 24"><rect x="9" y="2" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>Copier toute la semaine</button>';
  wrap.innerHTML=html;
  wrap.querySelectorAll('[data-ci]').forEach(function(btn){btn.onclick=function(){copyDay(parseInt(btn.dataset.ci));};});
  var ca=document.getElementById('cpAll');
  if(ca)ca.onclick=function(){
    var all=DAYS.map(function(_,i){return dayLines(i).join('\n');}).join('\n\n');
    navigator.clipboard.writeText(all).then(function(){showToast('✓ Semaine copiée');}).catch(function(){alert(all);});
  };
}

