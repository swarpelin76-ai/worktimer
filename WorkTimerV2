<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, viewport-fit=cover">
<meta name="apple-mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
<meta name="apple-mobile-web-app-title" content="WorkTimer">
<title>PM Alpes · WorkTimer</title>
<link rel="apple-touch-icon" href="data:image/png;base64,">
<style>
*{box-sizing:border-box;margin:0;padding:0;-webkit-tap-highlight-color:transparent;-webkit-font-smoothing:antialiased;}
html,body{overflow-x:hidden;max-width:100vw;background:var(--bg0);color:var(--lbl);font-family:-apple-system,'Helvetica Neue',sans-serif;}
:root{
  --tint:#C9954A;--tint-dim:rgba(201,149,74,.15);--tint-glow:rgba(201,149,74,.28);
  --green:#30D158;--red:#FF453A;--blue:#0A84FF;
  --bg0:#E8EAED;--bg1:#ECEEF1;--bg2:#F4F5F7;--bg3:#FFFFFF;--bg4:#DDE0E5;
  --sep:rgba(0,0,0,.08);--lbl:rgba(0,0,0,.88);--lbl2:rgba(0,0,0,.55);
  --lbl3:rgba(0,0,0,.35);--lbl4:rgba(0,0,0,.12);
  --sh-light:#FFFFFF;--sh-dark:#C8CAD0;
  --neu:4px 4px 12px var(--sh-dark),-3px -3px 10px var(--sh-light);
  --neu-sm:2px 2px 6px var(--sh-dark),-1px -1px 5px var(--sh-light);
  --blur:saturate(200%) blur(24px);
  --r:12px;--r-lg:18px;--r-xl:24px;--r-pill:100px;
  --sp:cubic-bezier(.34,1.56,.64,1);--ease:cubic-bezier(.25,.46,.45,.94);
}
.page{display:none;min-height:100vh;padding-bottom:max(90px,calc(70px + env(safe-area-inset-bottom)));animation:fadeUp .25s var(--ease) both;}
.page.active{display:block;}
@keyframes fadeUp{from{opacity:0;transform:translateY(10px);}to{opacity:1;transform:translateY(0);}}

/* HEADER */
.hdr{padding:max(54px,env(safe-area-inset-top)) 20px 14px;background:rgba(236,238,241,.85);backdrop-filter:var(--blur);-webkit-backdrop-filter:var(--blur);position:sticky;top:0;z-index:50;border-bottom:.5px solid var(--sep);}
.hdr-row{display:flex;align-items:center;justify-content:space-between;}
.hdr-left{}
.hdr-title{font-size:1.7rem;font-weight:700;letter-spacing:-.04em;line-height:1;}
.hdr-sub{font-size:.6rem;color:var(--lbl3);letter-spacing:.1em;text-transform:uppercase;margin-top:2px;}
.hdr-right{display:flex;align-items:center;gap:6px;}
.wk-prev,.wk-next{width:30px;height:30px;border-radius:50%;background:var(--bg2);border:none;color:var(--lbl2);font-size:1rem;cursor:pointer;display:flex;align-items:center;justify-content:center;transition:all .2s var(--sp);box-shadow:var(--neu-sm);}
.wk-prev:active,.wk-next:active{transform:scale(.85);background:var(--bg3);}
.wk-prev:disabled,.wk-next:disabled{opacity:.3;pointer-events:none;}
.wk-badge{background:var(--bg2);border-radius:var(--r-pill);padding:6px 13px;font-size:.73rem;font-weight:600;color:var(--lbl2);border:.5px solid var(--sep);white-space:nowrap;}
.wk-badge.now{color:var(--tint);border-color:var(--tint-dim);}

/* DAYS */
.day-strip{display:flex;gap:8px;padding:14px 20px;overflow-x:auto;scrollbar-width:none;-webkit-overflow-scrolling:touch;}
.day-strip::-webkit-scrollbar{display:none;}
.day-pill{flex-shrink:0;min-width:56px;display:flex;flex-direction:column;align-items:center;gap:2px;padding:9px 10px;border-radius:var(--r);background:var(--bg1);box-shadow:var(--neu-sm);border:none;cursor:pointer;transition:all .22s var(--sp);}
.day-pill.active{background:var(--tint);border-color:transparent;transform:scale(1.06);box-shadow:0 5px 18px var(--tint-glow);}
.dp-name{font-size:.7rem;font-weight:600;color:var(--lbl3);text-transform:uppercase;letter-spacing:.04em;}
.dp-date{font-size:.95rem;font-weight:700;color:var(--lbl2);}
.dp-dot{width:4px;height:4px;border-radius:50%;background:var(--tint);margin-top:1px;}
.day-pill.active .dp-name,.day-pill.active .dp-date{color:#000;}
.day-pill.active .dp-dot{background:rgba(0,0,0,.4);}

/* RING */
.ring-card{margin:0 16px 14px;background:var(--bg1);border-radius:var(--r-xl);border:none;box-shadow:var(--neu);padding:18px;display:flex;align-items:center;gap:18px;}
.ring-wrap{position:relative;width:100px;height:100px;flex-shrink:0;}
.ring-outer{
  width:96px;height:96px;border-radius:50%;
  background:var(--bg1);
  box-shadow:5px 5px 14px var(--sh-dark),-4px -4px 12px var(--sh-light);
  display:flex;align-items:center;justify-content:center;
  position:relative;
  flex-shrink:0;
}
.ring-outer svg{transform:rotate(-90deg);position:absolute;width:88px;height:88px;}
.ring-track{fill:none;stroke:var(--sh-dark);stroke-width:6;}
.ring-prog{fill:none;stroke:var(--tint);stroke-width:6;stroke-linecap:round;stroke-dasharray:238.8;stroke-dashoffset:238.8;transition:stroke-dashoffset .7s var(--ease),stroke .3s;filter:drop-shadow(0 0 4px var(--tint-glow));}
.ring-prog.over{stroke:var(--red);}
.ring-inner{
  width:66px;height:66px;border-radius:50%;
  background:var(--bg1);
  box-shadow:inset 3px 3px 8px var(--sh-dark),inset -2px -2px 6px var(--sh-light);
  display:flex;flex-direction:column;align-items:center;justify-content:center;
  z-index:1;
}
.ring-val{font-size:1.3rem;font-weight:700;letter-spacing:-.04em;line-height:1;}
.ring-target{font-size:.78rem;color:var(--lbl3);font-weight:500;margin-top:1px;}
.ring-mid{display:contents;}
.ring-side{}
.rs-lbl{font-size:.72rem;font-weight:600;color:var(--lbl3);text-transform:uppercase;letter-spacing:.1em;margin-bottom:4px;}
.rs-diff{font-size:1.7rem;font-weight:700;letter-spacing:-.04em;line-height:1;color:var(--tint);}
.rs-diff.over{color:var(--red);}
.rs-detail{font-size:.82rem;color:var(--lbl3);margin-top:2px;}

/* SECTION */
.sec-hd{padding:2px 20px 8px;display:flex;align-items:center;justify-content:space-between;}
.sec-lbl{font-size:.72rem;font-weight:600;color:var(--lbl3);text-transform:uppercase;letter-spacing:.1em;}
.sec-date{font-size:.72rem;color:var(--lbl3);}

/* TASKS */
.tasks{padding:0 16px;display:flex;flex-direction:column;gap:14px;}
.tc{background:var(--bg2);border-radius:var(--r-xl);border:none;box-shadow:var(--neu);overflow:hidden;transition:box-shadow .2s;}
.tc.run{box-shadow:0 0 0 2px var(--tint),var(--neu);}
.tc.locked{box-shadow:0 0 0 2px rgba(52,199,89,.4),var(--neu);}
.tc-top{padding:18px 18px 12px;}
.tc-row1{display:flex;align-items:center;gap:8px;margin-bottom:3px;}
.tc-cl{flex:1;background:transparent;border:none;font-family:inherit;font-size:1.15rem;font-weight:800;color:var(--lbl);outline:none;letter-spacing:-.02em;min-width:0;}
.tc-cl::placeholder{color:var(--lbl4);font-weight:400;}
.tc-badge{flex-shrink:0;display:flex;align-items:center;gap:4px;font-size:.75rem;font-weight:600;padding:3px 9px;border-radius:var(--r-pill);background:var(--bg3);color:var(--lbl3);}
.tc-bdot{width:5px;height:5px;border-radius:50%;background:var(--bg4);}
.tc.run .tc-badge .tc-bdot{background:var(--tint);animation:pulse 1.4s infinite;}
.tc.locked .tc-badge{background:rgba(48,209,88,.1);color:var(--green);}
.tc.locked .tc-badge .tc-bdot{background:var(--green);animation:none;}
@keyframes pulse{0%,100%{opacity:1;}50%{opacity:.3;}}
.tc-obj{width:100%;background:transparent;border:none;font-family:inherit;font-size:.9rem;color:var(--lbl3);outline:none;padding:2px 0;}
.tc-obj::placeholder{color:var(--lbl4);}

/* Timer */
.tc-timer-sec{padding:14px 18px 16px;border-top:.5px solid var(--sep);}
.tc-time{font-size:2.8rem;font-weight:300;letter-spacing:-.04em;font-variant-numeric:tabular-nums;line-height:1;margin-bottom:11px;transition:color .2s;}
.tc.run .tc-time{color:var(--tint);}
.tc-locked-sec{padding:14px 18px 16px;border-top:.5px solid var(--sep);display:flex;align-items:baseline;gap:10px;}
.tcl-val{font-size:2.5rem;font-weight:300;letter-spacing:-.04em;color:var(--green);line-height:1;}
.tcl-raw{font-size:.72rem;color:var(--lbl3);background:var(--bg3);padding:2px 8px;border-radius:5px;}

.tc-btns{display:flex;gap:7px;flex-wrap:wrap;}
.btn{display:inline-flex;align-items:center;gap:6px;height:42px;padding:0 16px;border-radius:var(--r-pill);border:none;font-family:inherit;font-size:.85rem;font-weight:600;cursor:pointer;transition:all .18s var(--sp);white-space:nowrap;}
.btn:active{transform:scale(.92);opacity:.75;}
.btn svg{width:13px;height:13px;flex-shrink:0;}
.btn-play{background:#1A1C22;color:#FFFFFF;box-shadow:2px 2px 8px rgba(0,0,0,.2),-1px -1px 5px #FFFFFF;flex:1;justify-content:center;height:52px;font-size:1rem;border-radius:26px;}
.btn-pause{background:var(--bg1);color:var(--lbl);box-shadow:var(--neu-sm);border:none;flex:1;justify-content:center;height:52px;font-size:1rem;border-radius:26px;}
.btn-ghost{background:var(--bg1);color:var(--lbl2);box-shadow:var(--neu-sm);border:none;}
.btn-red{background:rgba(255,69,58,.08);color:var(--red);border:.5px solid rgba(255,69,58,.18);}
.btn-lock{background:var(--bg1);color:var(--lbl2);box-shadow:var(--neu-sm);border:none;}
.btn-locked{background:rgba(48,209,88,.1);color:var(--green);border:.5px solid rgba(48,209,88,.22);}
.btn-blue{background:var(--bg1);color:var(--lbl2);box-shadow:var(--neu-sm);border:none;}

.tc-manual{display:flex;align-items:center;gap:10px;padding:14px 18px 16px;border-top:.5px solid var(--sep);}
.tc-ml{font-size:.75rem;font-weight:700;color:var(--lbl3);text-transform:uppercase;letter-spacing:.08em;flex-shrink:0;}
.tc-mi{background:var(--bg3);border:.5px solid var(--sep);border-radius:7px;padding:5px 11px;font-family:inherit;font-size:.85rem;font-weight:600;color:var(--lbl);outline:none;width:76px;text-align:center;transition:border-color .2s;}
.tc-mi:focus{border-color:var(--tint);}
.tc-mh{font-size:.7rem;color:var(--lbl3);}

.tc-lock-row{padding:0 18px 16px;display:flex;gap:7px;flex-wrap:wrap;}

.add-task{display:flex;align-items:center;justify-content:center;gap:7px;margin:8px 16px;height:46px;border-radius:var(--r-xl);background:transparent;border:.5px dashed var(--sep);font-family:inherit;font-size:.85rem;font-weight:500;color:var(--lbl3);cursor:pointer;transition:all .18s;width:calc(100% - 32px);}
.add-task:active{background:var(--bg2);}
.add-task svg{stroke:var(--lbl3);fill:none;width:14px;height:14px;stroke-width:2;stroke-linecap:round;}

/* HORAIRES */
.hor{margin:14px 16px 8px;background:var(--bg1);border-radius:var(--r-xl);border:none;box-shadow:var(--neu);overflow:hidden;}
.hor-fields{display:flex;}
.hor-f{flex:1;padding:13px 15px;background:var(--bg2);}
.hor-f:first-child{border-right:.5px solid var(--sep);}
.hor-lbl{font-size:.57rem;font-weight:600;color:var(--lbl3);text-transform:uppercase;letter-spacing:.1em;margin-bottom:3px;}
.hor-inp{background:transparent;border:none;font-family:inherit;font-size:1.25rem;font-weight:600;color:var(--lbl);outline:none;width:100%;-webkit-appearance:none;font-variant-numeric:tabular-nums;letter-spacing:-.03em;}
.hor-pause{padding:10px 15px;border-top:.5px solid var(--sep);}
.hor-pause-lbl{font-size:.57rem;font-weight:600;color:var(--lbl3);text-transform:uppercase;letter-spacing:.1em;margin-bottom:7px;}
.pause-btns{display:flex;gap:5px;overflow-x:auto;scrollbar-width:none;flex-wrap:nowrap;}
.pause-btns::-webkit-scrollbar{display:none;}
.pbtn{flex-shrink:0;height:28px;padding:0 11px;border-radius:var(--r-pill);border:.5px solid var(--sep);background:var(--bg3);font-family:inherit;font-size:.72rem;font-weight:600;color:var(--lbl3);cursor:pointer;transition:all .18s var(--sp);}
.pbtn.on{background:var(--tint);color:#000;border-color:transparent;}
.pbtn-c{flex-shrink:0;height:28px;padding:0 9px;border-radius:var(--r-pill);border:.5px solid var(--sep);background:var(--bg3);font-family:inherit;font-size:.72rem;font-weight:600;color:var(--lbl3);outline:none;width:52px;text-align:center;-webkit-appearance:none;}
.hor-dur{display:flex;align-items:center;justify-content:space-between;padding:10px 15px;border-top:.5px solid var(--sep);}
.hor-dur-info .hd-lbl{font-size:.72rem;color:var(--lbl3);}
.hor-dur-info .hd-rnd{font-size:.65rem;color:var(--lbl3);}
.hor-dur-val{font-size:1.45rem;font-weight:600;color:var(--tint);letter-spacing:-.03em;font-variant-numeric:tabular-nums;}

.notes-ta{width:100%;background:transparent;border:none;font-family:inherit;font-size:.85rem;color:var(--lbl2);resize:none;outline:none;padding:13px 15px;min-height:68px;line-height:1.5;}
.notes-ta::placeholder{color:var(--lbl4);}

/* WEEK */
.wk-wrap{padding:14px 16px;}
.wk-card{background:var(--bg1);border-radius:var(--r-xl);border:none;box-shadow:var(--neu);margin-bottom:10px;overflow:hidden;}
.wk-head{display:flex;align-items:flex-start;justify-content:space-between;padding:13px 15px 11px;border-bottom:.5px solid var(--sep);}
.wk-dn{font-size:.92rem;font-weight:700;letter-spacing:-.02em;}
.wk-dh{font-size:.72rem;color:var(--lbl3);margin-top:1px;}
.wk-cp{height:28px;padding:0 11px;border-radius:var(--r-pill);border:.5px solid var(--sep);background:var(--bg3);font-family:inherit;font-size:.7rem;font-weight:600;color:var(--lbl2);cursor:pointer;display:flex;align-items:center;gap:4px;flex-shrink:0;transition:all .18s;}
.wk-cp svg{width:11px;height:11px;stroke:currentColor;fill:none;stroke-width:2;stroke-linecap:round;}
.wk-tasks-list{padding:7px 15px 9px;}
.wk-tr{display:flex;justify-content:space-between;padding:4px 0;border-bottom:.5px solid var(--sep);}
.wk-tr:last-child{border:none;}
.wk-tn{font-size:.8rem;color:var(--lbl2);}
.wk-tt{font-size:.8rem;font-weight:700;color:var(--tint);font-variant-numeric:tabular-nums;}
.wk-empty-t{padding:7px 15px 9px;font-size:.78rem;color:var(--lbl4);font-style:italic;}
.wk-total-card{margin:0 0 14px;background:linear-gradient(135deg,var(--tint),#E8920A);border-radius:var(--r-xl);padding:15px 18px;display:flex;align-items:center;justify-content:space-between;box-shadow:0 5px 20px var(--tint-glow);}
.wtc-l{font-size:.6rem;font-weight:600;color:rgba(0,0,0,.5);text-transform:uppercase;letter-spacing:.1em;}
.wtc-v{font-size:1.9rem;font-weight:700;color:#000;letter-spacing:-.04em;font-variant-numeric:tabular-nums;}

/* COPIER */
.cp-wrap{padding:14px 16px;display:flex;flex-direction:column;gap:10px;}
.cp-card{background:var(--bg1);border-radius:var(--r-xl);border:none;box-shadow:var(--neu);overflow:hidden;}
.cp-head{display:flex;align-items:flex-start;justify-content:space-between;padding:13px 15px 9px;border-bottom:.5px solid var(--sep);}
.cp-dn{font-size:.9rem;font-weight:700;letter-spacing:-.02em;}
.cp-dh{font-size:.7rem;color:var(--lbl3);margin-top:1px;}
.cp-btn{height:28px;padding:0 11px;border-radius:var(--r-pill);border:.5px solid var(--sep);background:var(--bg3);font-family:inherit;font-size:.7rem;font-weight:600;color:var(--lbl2);cursor:pointer;display:flex;align-items:center;gap:4px;flex-shrink:0;transition:all .18s;}
.cp-btn svg{width:11px;height:11px;stroke:currentColor;fill:none;stroke-width:2;stroke-linecap:round;}
.cp-lines{padding:9px 15px 11px;font-size:.8rem;color:var(--lbl3);line-height:1.8;white-space:pre-wrap;}
.cp-all{display:flex;align-items:center;justify-content:center;gap:7px;height:48px;border-radius:var(--r-xl);background:var(--tint);border:none;font-family:inherit;font-size:.88rem;font-weight:700;color:#000;cursor:pointer;transition:all .18s;box-shadow:0 5px 18px var(--tint-glow);}
.cp-all:active{transform:scale(.97);}
.cp-all svg{stroke:#000;fill:none;width:15px;height:15px;stroke-width:2;stroke-linecap:round;}

/* CLIENTS */
.cl-wrap{padding:14px 16px;}
.per-card{background:var(--bg1);border-radius:var(--r-xl);border:none;box-shadow:var(--neu);margin-bottom:12px;overflow:hidden;}
.per-top{padding:13px 15px 10px;border-bottom:.5px solid var(--sep);}
.per-lbl{font-size:.57rem;font-weight:600;color:var(--lbl3);text-transform:uppercase;letter-spacing:.1em;margin-bottom:8px;}
.per-btns{display:flex;gap:5px;}
.per-btn{height:28px;padding:0 13px;border-radius:var(--r-pill);border:.5px solid var(--sep);background:var(--bg3);font-family:inherit;font-size:.72rem;font-weight:600;color:var(--lbl3);cursor:pointer;transition:all .18s var(--sp);}
.per-btn.on{background:var(--tint);color:#000;border-color:transparent;}
.per-dates{display:flex;align-items:center;gap:7px;padding:10px 15px;}
.per-inp{flex:1;height:34px;padding:0 11px;background:var(--bg2);border:.5px solid var(--sep);border-radius:8px;font-family:inherit;font-size:.8rem;color:var(--lbl);outline:none;-webkit-appearance:none;transition:border-color .18s;}
.per-inp:focus{border-color:var(--tint);}
.per-sep{font-size:.72rem;color:var(--lbl3);}
.per-ok{height:34px;padding:0 14px;border-radius:var(--r-pill);background:var(--tint);border:none;font-family:inherit;font-size:.8rem;font-weight:700;color:#000;cursor:pointer;flex-shrink:0;transition:all .18s;}
.filter-wrap{position:relative;margin-bottom:12px;}
.filter-ic{position:absolute;left:11px;top:50%;transform:translateY(-50%);width:13px;height:13px;stroke:var(--lbl3);fill:none;stroke-width:2;stroke-linecap:round;pointer-events:none;}
.filter-inp{width:100%;height:38px;padding:0 13px 0 33px;background:var(--bg1);box-shadow:var(--neu-sm);border:none;border-radius:var(--r);font-family:inherit;font-size:.85rem;color:var(--lbl);outline:none;-webkit-appearance:none;transition:border-color .18s;}
.filter-inp:focus{border-color:var(--tint);}
.cl-total-card{background:linear-gradient(135deg,var(--tint),#E8920A);border-radius:var(--r-xl);padding:14px 17px;margin-bottom:12px;display:flex;align-items:center;justify-content:space-between;box-shadow:0 5px 20px var(--tint-glow);}
.ctc-l{font-size:.58rem;font-weight:600;color:rgba(0,0,0,.5);text-transform:uppercase;letter-spacing:.1em;}
.ctc-p{font-size:.7rem;color:rgba(0,0,0,.4);margin-top:1px;}
.ctc-v{font-size:1.8rem;font-weight:700;color:#000;letter-spacing:-.04em;font-variant-numeric:tabular-nums;}
.cl-block{background:var(--bg1);border-radius:var(--r-xl);border:none;box-shadow:var(--neu);margin-bottom:10px;overflow:hidden;}
.cl-block-head{display:flex;align-items:center;justify-content:space-between;padding:13px 15px 11px;border-bottom:.5px solid var(--sep);}
.cl-name{font-size:.95rem;font-weight:700;letter-spacing:-.02em;}
.cl-tot{font-size:.88rem;font-weight:700;color:var(--tint);font-variant-numeric:tabular-nums;}
.cl-row{display:flex;align-items:center;gap:8px;padding:8px 15px;border-bottom:.5px solid var(--sep);}
.cl-row:last-child{border:none;}
.cl-dt{font-size:.68rem;color:var(--lbl3);font-weight:500;flex-shrink:0;width:76px;}
.cl-ob{flex:1;font-size:.82rem;color:var(--lbl2);}
.cl-tm{font-size:.8rem;font-weight:700;color:var(--tint);font-variant-numeric:tabular-nums;flex-shrink:0;}
.cl-ck{font-size:.58rem;color:var(--green);background:rgba(48,209,88,.1);padding:1px 5px;border-radius:4px;flex-shrink:0;}
.empty-st{text-align:center;padding:40px 20px;color:var(--lbl3);}
.empty-st .ei{font-size:2.2rem;margin-bottom:10px;}
.empty-st .et{font-size:.88rem;font-weight:600;margin-bottom:5px;color:var(--lbl2);}
.empty-st .es{font-size:.78rem;color:var(--lbl4);}
.exp-btns{display:flex;gap:9px;margin-top:12px;}
.exp-btn{flex:1;height:46px;border-radius:var(--r-xl);font-family:inherit;font-size:.85rem;font-weight:600;cursor:pointer;display:flex;align-items:center;justify-content:center;gap:7px;transition:all .18s;border:.5px solid var(--sep);}
.exp-btn:active{transform:scale(.97);}
.exp-cp{background:var(--bg2);color:var(--lbl);}
.exp-sv{background:var(--tint);color:#000;border-color:transparent;box-shadow:0 4px 14px var(--tint-glow);}
.exp-btn svg{stroke:currentColor;fill:none;width:14px;height:14px;stroke-width:2;stroke-linecap:round;}

/* RAPPELS */
.rp-wrap{padding:14px 16px;}
.rp-form{background:var(--bg1);border-radius:var(--r-xl);border:none;box-shadow:var(--neu);padding:15px;margin-bottom:14px;}
.rp-form-lbl{font-size:.57rem;font-weight:600;color:var(--lbl3);text-transform:uppercase;letter-spacing:.1em;margin-bottom:10px;}
.rp-inp{width:100%;height:40px;padding:0 13px;background:var(--bg2);border:.5px solid var(--sep);border-radius:8px;font-family:inherit;font-size:.88rem;color:var(--lbl);outline:none;-webkit-appearance:none;margin-bottom:8px;transition:border-color .18s;}
.rp-inp:focus{border-color:var(--tint);}
.rp-add{width:100%;height:44px;background:var(--tint);color:#000;border:none;border-radius:var(--r-lg);font-family:inherit;font-size:.88rem;font-weight:700;cursor:pointer;transition:all .18s;}
.rp-add:active{transform:scale(.97);}
.rp-item{background:var(--bg1);border-radius:var(--r-lg);border:none;box-shadow:var(--neu-sm);border-left:3px solid var(--bg4);padding:13px 14px;margin-bottom:8px;display:flex;align-items:center;gap:11px;transition:all .2s;}
.rp-item.today{border-left-color:var(--tint);background:rgba(255,159,10,.05);animation:rpBlink 2s ease-in-out infinite;}
.rp-item.past{opacity:.45;}
@keyframes rpBlink{0%,100%{box-shadow:0 0 0 1px transparent;}50%{box-shadow:0 0 0 1.5px rgba(255,159,10,.35);}}
.rp-icon{font-size:1.3rem;flex-shrink:0;}
.rp-info{flex:1;min-width:0;}
.rp-date{font-size:.68rem;font-weight:700;color:var(--lbl3);margin-bottom:2px;}
.rp-date.today{color:var(--tint);}
.rp-msg{font-size:.9rem;font-weight:600;color:var(--lbl);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;}
.rp-del{width:28px;height:28px;border-radius:7px;background:var(--bg3);border:none;color:var(--red);cursor:pointer;display:flex;align-items:center;justify-content:center;font-size:.75rem;flex-shrink:0;}
.rp-empty{text-align:center;padding:30px 20px;color:var(--lbl4);font-size:.82rem;}

/* TAB BAR */
.tabbar{position:fixed;bottom:0;left:0;right:0;z-index:100;background:rgba(236,238,241,.92);backdrop-filter:var(--blur);-webkit-backdrop-filter:var(--blur);border-top:.5px solid var(--sep);display:flex;padding:7px 0 max(18px,env(safe-area-inset-bottom));}
.tab{flex:1;display:flex;flex-direction:column;align-items:center;gap:2px;background:none;border:none;cursor:pointer;padding:4px 0;transition:all .18s;-webkit-appearance:none;appearance:none;outline:none;}
.tab svg{width:22px;height:22px;stroke:rgba(0,0,0,.35);fill:none;stroke-width:1.6;stroke-linecap:round;stroke-linejoin:round;transition:all .22s var(--sp);}
.tab span{font-size:.68rem;font-weight:500;color:rgba(0,0,0,.35);letter-spacing:.02em;transition:color .18s;}
.tab.active svg{stroke:var(--tint);transform:scale(1.1);}
.tab.active span{color:var(--tint);font-weight:600;}
.tab.alert svg{stroke:var(--red);}
.tab.alert span{color:var(--red);}
.tab.alert{animation:tabAlert 1.8s ease-in-out infinite;}
@keyframes tabAlert{0%,100%{opacity:1;}50%{opacity:.55;}}

/* LIVE BANNER */
.live-banner{position:fixed;top:0;left:0;right:0;z-index:200;background:rgba(236,238,241,.92);backdrop-filter:var(--blur);-webkit-backdrop-filter:var(--blur);border-bottom:.5px solid var(--sep);display:flex;align-items:center;justify-content:center;gap:10px;padding:max(52px,env(safe-area-inset-top)) 20px 10px;transform:translateY(-100%);transition:transform .35s var(--sp);}
.live-banner.on{transform:translateY(0);}
.live-dot{width:8px;height:8px;border-radius:50%;background:var(--tint);animation:pulse 1.4s infinite;flex-shrink:0;}
.live-task{font-size:.75rem;font-weight:600;color:var(--lbl2);flex:1;overflow:hidden;white-space:nowrap;text-overflow:ellipsis;}
.live-time{font-size:.75rem;font-weight:700;color:var(--tint);font-variant-numeric:tabular-nums;flex-shrink:0;} 

/* TOAST */
.toast{position:fixed;bottom:max(88px,calc(66px + env(safe-area-inset-bottom)));left:50%;transform:translateX(-50%) translateY(8px);background:rgba(50,50,55,.9);backdrop-filter:var(--blur);-webkit-backdrop-filter:var(--blur);color:#fff;padding:10px 18px;border-radius:var(--r-pill);font-size:.82rem;font-weight:600;border:.5px solid var(--sep);opacity:0;transition:all .28s var(--sp);pointer-events:none;z-index:500;white-space:nowrap;box-shadow:0 6px 24px rgba(0,0,0,.15);}
.toast.show{opacity:1;transform:translateX(-50%) translateY(0);}

/* INSTALL BANNER */
.install-ban{position:fixed;top:0;left:0;right:0;z-index:900;padding:max(52px,env(safe-area-inset-top)) 16px 14px;background:rgba(236,238,241,.95);backdrop-filter:var(--blur);-webkit-backdrop-filter:var(--blur);border-bottom:.5px solid var(--sep);transform:translateY(-100%);transition:transform .35s var(--sp);}
.install-ban.show{transform:translateY(0);}
.ib-row{display:flex;align-items:flex-start;gap:11px;}
.ib-steps{flex:1;font-size:.78rem;color:var(--lbl2);line-height:1.7;}
.ib-steps strong{color:var(--tint);}
.ib-close{width:26px;height:26px;border-radius:50%;background:var(--bg3);border:none;color:var(--lbl3);font-size:.82rem;cursor:pointer;flex-shrink:0;display:flex;align-items:center;justify-content:center;}
</style>
</head>
