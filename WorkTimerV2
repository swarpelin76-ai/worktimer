function taskCardHTML(t,i){
  var isR=runningTimer&&runningTimer.taskId===t.id&&runningTimer.dayIdx===i&&runningTimer.wk===weekOffset;
  var el=getLive(t.id,i);
  var isL=t.locked===true;
  var elRnd=s2hm_rnd(el);
  var elRaw=s2hms(el);
  var canCarry=!t.recurring;
  var nextLabel=i===4?'Lundi prochain':DAYS[i+1];
  var carriedTag=t.carriedFrom?'<span style="font-size:.6rem;font-weight:600;color:var(--blue);background:rgba(10,132,255,.1);padding:2px 7px;border-radius:20px;flex-shrink:0;">↩ reportée</span>':'';

  var timerHTML=isL
    ?('<div class="tc-locked-sec"><span class="tcl-val">'+(t.manual||elRnd)+'</span><span class="tcl-raw">brut '+elRaw+'</span></div>')
    :('<div class="tc-timer-sec"><div class="tc-time" id="td_'+t.id+'">'+elRaw+'</div>'
      +'<div class="tc-btns">'
      +'<button class="btn '+(isR?'btn-pause':'btn-play')+'" data-tid="'+t.id+'" data-di="'+i+'">'
      +(isR
        ?'<svg viewBox="0 0 24 24" fill="currentColor"><rect x="6" y="4" width="4" height="16" rx="1"/><rect x="14" y="4" width="4" height="16" rx="1"/></svg>Pause'
        :(el>0
          ?'<svg viewBox="0 0 24 24" fill="currentColor"><polygon points="5 3 19 12 5 21"/></svg>Reprendre'
          :'<svg viewBox="0 0 24 24" fill="currentColor"><polygon points="5 3 19 12 5 21"/></svg>Démarrer'))
      +'</button>'
      +'<button class="btn btn-ghost" data-rid="'+t.id+'" data-di="'+i+'">'
      +'<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"><path d="M3 12a9 9 0 1 0 9-9 9.75 9.75 0 0 0-6.74 2.74L3 8"/><path d="M3 3v5h5"/></svg>'
      +'Remettre à zéro</button>'
      +(canCarry?'<button class="btn btn-blue" data-carry="'+t.id+'" data-di="'+i+'">'+(t.carriedTo?'✓ Reporté':'↷ '+nextLabel)+'</button>':'')
      +'<button class="btn btn-red" data-del="'+t.id+'">Supprimer</button>'
      +'</div></div>');

  var manualHTML=isL?'':('<div class="tc-manual">'
    +'<span class="tc-ml">Manuel</span>'
    +'<input class="tc-mi" type="text" value="'+esc(t.manual||'')+'" placeholder="2h30" data-f="manual" data-id="'+t.id+'">'
    +'<span class="tc-mh">prioritaire</span>'
    +'</div>');

  return '<div class="tc'+(isR?' run':'')+(isL?' locked':'')+'" id="ti_'+t.id+'">'
    +'<div class="tc-top">'
    +'<div class="tc-row1">'
    +'<input class="tc-cl" type="text" value="'+esc(t.client||'')+'" placeholder="Nom du client…" data-f="client" data-id="'+t.id+'"'+(isL?' readonly':'')+'>'
    +'<span class="tc-badge"><span class="tc-bdot"></span>'+(isL?'Validé':'En cours')+'</span>'
    +'</div>'
    +(carriedTag?'<div style="margin-bottom:4px;">'+carriedTag+'</div>':'')
    +'<input class="tc-obj" type="text" value="'+esc(t.object||'')+'" placeholder="Objet (armoire, terrasse…)" data-f="object" data-id="'+t.id+'"'+(isL?' readonly':'')+'>'
    +'</div>'
    +timerHTML+manualHTML
    +'<div class="tc-lock-row">'
    +'<button class="btn '+(isL?'btn-locked':'btn-lock')+'" data-lock="'+t.id+'" data-di="'+i+'">'
    +(isL
      ?'<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" width="13" height="13"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>Verrouillé'
      :'<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" width="13" height="13"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 9.9-1"/></svg>Valider')
    +'</button>'
    +(isL?'<button class="btn btn-red" data-del="'+t.id+'">Supprimer</button>':'')
